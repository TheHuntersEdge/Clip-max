// ClipMax — Prisma schema
// Auth.js (NextAuth) models + the ClipMax domain model.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Auth.js / NextAuth models (required by @auth/prisma-adapter)
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts    Account[]
  sessions    Session[]
  memberships Membership[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// ClipMax domain model (starting point — brief §"Data model")
// NOTE: the brief's "Account" (social posting account) is named
// SocialAccount here to avoid colliding with Auth.js's Account.
// ============================================================

enum Role {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum SourcePlatform {
  TWITCH
  KICK
  YOUTUBE
}

enum SourceStatus {
  CONNECTED
  DISCONNECTED
  ERROR
}

enum StreamStatus {
  LIVE
  PROCESSING
  DONE
  FAILED
}

enum ClipStatus {
  PENDING
  RENDERING
  READY
  SCHEDULED
  POSTED
  FAILED
}

enum SocialPlatform {
  TIKTOK
  INSTAGRAM
  YOUTUBE
  FACEBOOK
}

enum AccountSource {
  CONNECTED
  PURCHASED
}

enum AccountHealth {
  HEALTHY
  WARN
  BANNED
}

enum PostStatus {
  SCHEDULED
  POSTED
  FAILED
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
}

enum WarmStatus {
  WARMING
  READY
}

enum ListingStatus {
  AVAILABLE
  RESERVED
  SOLD
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  plan      String   @default("free")
  createdAt DateTime @default(now())

  memberships    Membership[]
  sources        Source[]
  socialAccounts SocialAccount[]
  campaigns      Campaign[]
}

model Membership {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  role        Role     @default(VIEWER)
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Source {
  id          String         @id @default(cuid())
  workspaceId String
  platform    SourcePlatform
  channelId   String
  oauthTokens Json?
  status      SourceStatus   @default(CONNECTED)
  createdAt   DateTime       @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  streams   Stream[]

  @@unique([platform, channelId])
}

model Stream {
  id        String       @id @default(cuid())
  sourceId  String
  vodUrl    String?
  title     String?
  startedAt DateTime?
  endedAt   DateTime?
  status    StreamStatus @default(LIVE)

  source Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  clips  Clip[]
}

model Clip {
  id        String     @id @default(cuid())
  streamId  String
  start     Float
  end       Float
  title     String?
  score     Int?
  reason    String?
  caption   String?
  status    ClipStatus @default(PENDING)
  renderUrl String?
  createdAt DateTime   @default(now())

  stream Stream @relation(fields: [streamId], references: [id], onDelete: Cascade)
  posts  Post[]
}

model SocialAccount {
  id          String         @id @default(cuid())
  workspaceId String
  platform    SocialPlatform
  handle      String
  followers   Int            @default(0)
  source      AccountSource  @default(CONNECTED)
  health      AccountHealth  @default(HEALTHY)
  createdAt   DateTime       @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  posts     Post[]
}

model Post {
  id          String     @id @default(cuid())
  clipId      String
  accountId   String
  scheduledAt DateTime?
  postedAt    DateTime?
  status      PostStatus @default(SCHEDULED)
  metrics     Json?

  clip    Clip          @relation(fields: [clipId], references: [id], onDelete: Cascade)
  account SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model Campaign {
  id             String         @id @default(cuid())
  workspaceId    String
  name           String
  targetAccounts Json?
  schedule       Json?
  status         CampaignStatus @default(DRAFT)
  createdAt      DateTime       @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model MarketListing {
  id         String         @id @default(cuid())
  platform   SocialPlatform
  niche      String
  ageMonths  Int
  followers  String
  warmStatus WarmStatus     @default(WARMING)
  region     String
  price      Int
  status     ListingStatus  @default(AVAILABLE)
  createdAt  DateTime       @default(now())
}
