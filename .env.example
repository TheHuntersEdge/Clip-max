# ─── ClipMax environment ───────────────────────────────────────────
# Copy to `.env` and fill in. Never commit the real `.env`.

# Postgres connection string (Supabase / Neon / local).
# Prisma reads this via prisma.config.ts.
DATABASE_URL="postgresql://user:password@localhost:5432/clipmax?schema=public"

# NextAuth / Auth.js
# Generate a secret with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=""

# GitHub OAuth provider (https://github.com/settings/developers)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Anthropic Claude — powers AI moment scoring (the core of the product)
ANTHROPIC_API_KEY=""

# Twitch (live detection + VOD lookup + EventSub)
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""
TWITCH_EVENTSUB_SECRET=""

# Deepgram (transcription)
DEEPGRAM_API_KEY=""

# Upload-Post (multi-account social posting). When set, the worker posts for
# real via Upload-Post for accounts linked to a profile (SocialAccount.externalId).
UPLOADPOST_API_KEY=""

# ─── Render worker only (Cloudflare R2 storage for finished clips) ──
# Needed by the worker service, not the Vercel web app.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="clipmax-clips"
R2_PUBLIC_BASE_URL=""   # e.g. https://pub-xxxx.r2.dev  or a custom domain

# ─── Phase 4+ (not used yet) ───────────────────────────────────────
# STRIPE_SECRET_KEY=""
